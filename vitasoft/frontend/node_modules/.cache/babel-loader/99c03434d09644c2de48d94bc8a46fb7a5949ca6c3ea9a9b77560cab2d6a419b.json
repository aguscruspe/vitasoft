{"ast":null,"code":"import{authTraffic}from'../traffic/authTraffic';export const authService={async login(email,contrasena){const{data}=await authTraffic.login(email,contrasena);if(data&&data.token){localStorage.setItem('token',data.token);localStorage.setItem('usuario',JSON.stringify({id:data.id,nombre:data.nombre,email:data.email,rol:data.rol}));}return data;},logout(){localStorage.clear();},getToken(){return localStorage.getItem('token');},getUsuario(){const raw=localStorage.getItem('usuario');return raw?JSON.parse(raw):null;},isAuthenticated(){return!!localStorage.getItem('token');}};","map":{"version":3,"names":["authTraffic","authService","login","email","contrasena","data","token","localStorage","setItem","JSON","stringify","id","nombre","rol","logout","clear","getToken","getItem","getUsuario","raw","parse","isAuthenticated"],"sources":["C:/Users/Administrator/vitasoft/frontend/src/services/authService.js"],"sourcesContent":["import { authTraffic } from '../traffic/authTraffic';\n\nexport const authService = {\n  async login(email, contrasena) {\n    const { data } = await authTraffic.login(email, contrasena);\n    if (data && data.token) {\n      localStorage.setItem('token', data.token);\n      localStorage.setItem('usuario', JSON.stringify({\n        id: data.id,\n        nombre: data.nombre,\n        email: data.email,\n        rol: data.rol,\n      }));\n    }\n    return data;\n  },\n\n  logout() {\n    localStorage.clear();\n  },\n\n  getToken() {\n    return localStorage.getItem('token');\n  },\n\n  getUsuario() {\n    const raw = localStorage.getItem('usuario');\n    return raw ? JSON.parse(raw) : null;\n  },\n\n  isAuthenticated() {\n    return !!localStorage.getItem('token');\n  },\n};\n"],"mappings":"AAAA,OAASA,WAAW,KAAQ,wBAAwB,CAEpD,MAAO,MAAM,CAAAC,WAAW,CAAG,CACzB,KAAM,CAAAC,KAAKA,CAACC,KAAK,CAAEC,UAAU,CAAE,CAC7B,KAAM,CAAEC,IAAK,CAAC,CAAG,KAAM,CAAAL,WAAW,CAACE,KAAK,CAACC,KAAK,CAAEC,UAAU,CAAC,CAC3D,GAAIC,IAAI,EAAIA,IAAI,CAACC,KAAK,CAAE,CACtBC,YAAY